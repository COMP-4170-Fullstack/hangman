<%- include('partials/header', { title: 'Home', user: user }) %>

<div class="hero">
  <div class="voxel-decorations">
    <div class="voxel-diamond voxel-cyan"></div>
    <div class="voxel-diamond voxel-magenta"></div>
    <div class="voxel-diamond voxel-yellow"></div>
  </div>
  
  <!-- ADD LOGO HERE -->
  <h1 class="hero-title">PIXEL HANGMAN</h1>
  <p class="hero-subtitle">Test your knowledge in Design, Frontend & Marketing</p>
  
  <div class="hero-buttons">
    <% if (user) { %>
      <a href="/game" class="title">PLAY NOW</a>
    <% } else { %>
      <a href="/auth" class="btn btn-primary btn-large">GET STARTED</a>
    <% } %>
    <a href="/scoreboard" class="btn btn-secondary btn-large">VIEW RANKING</a>
  </div>
</div>

 <!-- REMOVE THIS? -->
<section class="features">
  <h2 class="section-title">HOW TO PLAY</h2>
  <div class="features-grid">
    <div class="feature-card">
      <div class="feature-icon voxel-cyan">1</div>
      <h3>Create your account</h3>
      <p>Sign up to save your score and compete on the global ranking</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon voxel-magenta">2</div>
      <h3>Guess the word</h3>
      <p>Choose letters to discover design, frontend and marketing words</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon voxel-yellow">3</div>
      <h3>Earn points</h3>
      <p>Win 100 points per victory + 25 bonus per consecutive streak</p>
    </div>
  </div>
</section>

<!-- REMOVE THIS? -->
<% if (topPlayers && topPlayers.length > 0) { %>
<section class="top-players">
  <h2 class="section-title">TOP PLAYERS</h2>
  <div class="top-players-grid">
    <% topPlayers.forEach((player, index) => { %>
      <div class="top-player-card rank-<%= index + 1 %>">
        <div class="rank-badge"><%= index + 1 %></div>
        <div class="player-info">
          <span class="player-name"><%= player.username %></span>
          <span class="player-score"><%= player.total_score %> pts</span>
        </div>
      </div>
    <% }) %>
  </div>
</section>
<% } %>


<!-- REMOVE THIS? -->
<section class="categories">
  <h2 class="section-title">CATEGORIES</h2>
  <div class="categories-grid">
    <div class="category-card">
      <div class="category-icon" aria-label="Paint Palette Emoji">&#127912;</div>
      <h3>Design</h3>
      <p>Typography, colors, UI/UX and more</p>
    </div>
    <div class="category-card">
      <div class="category-icon" aria-label="Laptop Emoji">&#128187;</div>
      <h3>Frontend</h3>
      <p>HTML, CSS, JavaScript, frameworks</p>
    </div>
    <div class="category-card">
      <div class="category-icon" aria-label="Graph Emoji">&#128200;</div>
      <h3>Marketing</h3>
      <p>SEO, analytics, conversion and growth</p>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
